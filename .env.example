# Authentication
IMG_AUTH_TOKEN="your-admin-token-here"
IMG_JWT_SECRET="generate-a-very-long-random-string-here"

# Database URL examples
# SQLite: make sure the parent directory is writable by the rs-ibed process.
IMG_DATABASE_URL="sqlite://data/image_host.db?mode=rwc"
# PostgreSQL: the app connects to the maintenance database first and may create the target database automatically.
# IMG_DATABASE_URL="postgres://ibed:change-me@localhost:5432/ibed"

# ---------------------------------------------------
# S3 Storage Endpoint Credentials (per-endpoint)
# ---------------------------------------------------
# For each S3 [[storage.endpoints]] entry in config.toml, provide
# credentials using the naming pattern:
#   IMG_ENDPOINT_{UPPER_NAME}__FIELD
#
# Name is uppercased and hyphens replaced with underscores.
# Example: for name = "minio-cache" → IMG_ENDPOINT_MINIO_CACHE__*
#
# Required fields:
#   IMG_ENDPOINT_MINIO_CACHE__ACCESS_KEY=minioadmin
#   IMG_ENDPOINT_MINIO_CACHE__SECRET_KEY=minioadmin
#
# Optional fields (can also be set in config.toml):
#   IMG_ENDPOINT_MINIO_CACHE__BUCKET=images
#   IMG_ENDPOINT_MINIO_CACHE__ENDPOINT_URL=http://minio:9000
#   IMG_ENDPOINT_MINIO_CACHE__REGION=us-east-1
