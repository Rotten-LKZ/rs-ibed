# Authentication
IMG_AUTH_TOKEN="your-admin-token-here"
IMG_JWT_SECRET="generate-a-very-long-random-string-here"

# Database URL examples
# SQLite: make sure the parent directory is writable by the rs-ibed process.
IMG_DATABASE_URL="sqlite://data/image_host.db?mode=rwc"
# PostgreSQL: the app connects to the maintenance database first and may create the target database automatically.
# IMG_DATABASE_URL="postgres://ibed:change-me@localhost:5432/ibed"
