          "304": {
            "description": "Not modified"
          },
          "404": {
            "description": "Not found"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AuthCheckResponse": {
        "type": "object",
        "required": [
          "ok",
          "user"
        ],
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "user": {
            "type": "string"
          }
        }
      },
      "AuthSuccessResponse": {
        "type": "object",
        "required": [
          "ok"
        ],
        "properties": {
          "ok": {
            "type": "boolean"
          }
        }
      },
      "CliLoginQuery": {
        "type": "object",
        "required": [
          "token"
        ],
        "properties": {
          "token": {
            "type": "string"
          }
        }
      },
      "DirectMode": {
        "type": "string",
        "description": "How clients access images stored on an S3 endpoint.",
        "enum": [
          "proxy",
          "presigned",
          "public"
        ]
      },
      "ImageCountResponse": {
        "type": "object",
        "required": [
          "active",
          "in_trash"
        ],
        "properties": {
          "active": {
            "type": "integer",
            "format": "int64"
          },
          "in_trash": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "ImageDetailResponse": {
        "type": "object",
        "required": [
          "image",
          "view_url"
        ],
        "properties": {
          "direct_url": {
            "type": [
              "string",
              "null"
            ]
          },
          "image": {
            "$ref": "#/components/schemas/ImageModel"
          },
          "storage_available": {
            "type": [
              "boolean",
              "null"
            ],
            "description": "Whether the image file is available on at least one active storage node.\nOnly populated in admin API responses; null means not checked."
          },
          "view_url": {
            "type": "string"
          }
        }
      },
      "ImageListItem": {
        "type": "object",
        "required": [
          "id",
          "hash",
          "display_name",
          "file_name",
          "extension",
          "mime_type",
          "size",
          "width",
          "height",
          "is_deleted",
          "created_at",
          "updated_at",
          "view_url"
        ],
        "properties": {
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "direct_url": {
            "type": [
              "string",
              "null"
            ]
          },
          "display_name": {
            "type": "string"
          },
          "extension": {
            "type": "string"
          },
          "file_name": {
            "type": "string"
          },
          "hash": {
            "type": "string"
          },
          "height": {
            "type": "integer",
            "format": "int32"
          },
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "is_deleted": {
            "type": "boolean"
          },
          "mime_type": {
            "type": "string"
          },
          "size": {
            "type": "integer",
            "format": "int64"
          },
          "storage_available": {
            "type": [
              "boolean",
              "null"
            ],
            "description": "Whether the image file is available on at least one active storage node.\nOnly populated in admin API responses; null means not checked."
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "user_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "view_url": {
            "type": "string"
          },
          "width": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "ImageListQuery": {
        "type": "object",
        "properties": {
          "date_from": {
            "type": [
              "string",
              "null"
            ],
            "description": "Start date (YYYY-MM-DD)"
          },
          "date_to": {
            "type": [
              "string",
              "null"
            ],
            "description": "End date (YYYY-MM-DD)"
          },
          "deleted": {
            "type": [
              "boolean",
              "null"
            ],
            "description": "Filter by deletion status; defaults to non-deleted images when omitted"
          },
          "name": {
            "type": [
              "string",
              "null"
            ],
            "description": "Fuzzy search by display_name"
          },
          "page": {
            "type": "integer",
            "format": "int64",
            "description": "Page number, starting from 1"
          },
          "per_page": {
            "type": "integer",
            "format": "int64",
            "description": "Items per page"
          }
        }
      },
      "ImageListResponse": {
        "type": "object",
        "required": [
          "items",
          "total",
          "page",
          "per_page"
        ],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ImageListItem"
            }
          },
          "page": {
            "type": "integer",
            "format": "int64"
          },
          "per_page": {
            "type": "integer",
            "format": "int64"
          },
          "total": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "ImageModel": {
        "type": "object",
        "required": [
          "id",
          "hash",
          "display_name",
          "file_name",
          "extension",
          "mime_type",
          "size",
          "width",
          "height",
          "is_deleted",
          "created_at",
          "updated_at"
        ],
        "properties": {
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "display_name": {
            "type": "string"
          },
          "extension": {
            "type": "string"
          },
          "file_name": {
            "type": "string"
          },
          "hash": {
            "type": "string"
          },
          "height": {
            "type": "integer",
            "format": "int32"
          },
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "is_deleted": {
            "type": "boolean"
          },
          "mime_type": {
            "type": "string"
          },
          "size": {
            "type": "integer",
            "format": "int64"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "user_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "width": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": [
          "token"
        ],
        "properties": {
          "token": {
            "type": "string"
          }
        }
      },
      "OkResponse": {
        "type": "object",
        "required": [
          "ok"
        ],
        "properties": {
          "ok": {
            "type": "boolean"
          }
        }
      },
      "RenameRequest": {
        "type": "object",
        "required": [
          "display_name"
        ],
        "properties": {
          "display_name": {
            "type": "string"
          }
        }
      },
      "StorageEndpointResponse": {
        "type": "object",
        "description": "Response returned by GET /api/admin/storage/endpoints —\nmerges live in-memory state with config-immutable fields.",
        "required": [
          "name",
          "description",
          "endpoint_type",
          "capacity_bytes",
          "used_size",
          "priority",
          "status",
          "direct_mode"
        ],
        "properties": {
          "capacity_bytes": {
            "type": "integer",
            "format": "int64"
          },
          "description": {
            "type": "string"
          },
          "direct_mode": {
            "$ref": "#/components/schemas/DirectMode",
            "description": "How clients access images: \"proxy\", \"presigned\", or \"public\"."
          },
          "endpoint_type": {
            "type": "string",
            "description": "Backend type from config: \"Local\" or \"S3\"."
          },
          "name": {
            "type": "string"
          },
          "priority": {
            "type": "integer",
            "format": "int32"
          },
          "status": {
            "type": "string"
          },
          "used_size": {
