    "/d/{path}": {
      "get": {
        "tags": [
          "handlers::view"
        ],
        "summary": "GET /d/{*path}",
        "operationId": "download",
        "parameters": [
          {
            "name": "path",
            "in": "path",
            "description": "Image path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Original image download"
          },
          "304": {
            "description": "Not modified"
          },
          "404": {
            "description": "Not found"
          }
        }
      }
    },
    "/v/{path}": {
      "get": {
        "tags": [
          "handlers::view"
        ],
        "summary": "GET /v/{*path}",
