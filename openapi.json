    "/api/auth/check": {
      "get": {
        "tags": [
          "handlers::auth"
        ],
        "summary": "GET /api/auth/check\nReturns 200 if the user is authenticated.",
        "operationId": "check",
        "responses": {
          "200": {
            "description": "Authenticated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthCheckResponse"
                }
              }
            }
          },
          "401": {
            "description": "Not authenticated"
          }
        },
        "security": [
          {
            "cookieAuth": []
          },
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/api/auth/cli": {
      "get": {
        "tags": [
          "handlers::auth"
        ],
        "summary": "GET /api/auth/cli?token=<one-time-token>\nValidates the one-time CLI token and sets JWT cookie.",
        "operationId": "cli_login",
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "description": "One-time CLI token",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Login successful, JWT cookie set",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthSuccessResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid or expired token"
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": [
          "handlers::auth"
        ],
        "summary": "POST /api/auth/login\nBody: { \"token\": \"<AUTH_TOKEN from .env>\" }",
        "operationId": "login",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Login successful, JWT cookie set",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthSuccessResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid token"
          }
        }
      }
    },
